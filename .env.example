# ============================================================
# PR Analyzer — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ---- GitHub OAuth App ----
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:8000/auth/github/callback
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# ---- JWT Auth ----
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_random_secret_key_here_at_least_32_chars

# ---- Rocketride ----
# WebSocket / HTTPS base of your RocketRide server (see ROCKETRIDE_QUICKSTART.md: ROCKETRIDE_URI)
ROCKETRIDE_URI=wss://your-rocketride.fly.dev
# Optional legacy alias: ROCKETRIDE_URL=https://your-rocketride.fly.dev
ROCKETRIDE_APIKEY=your_rocketride_api_key
# Optional legacy alias: ROCKETRIDE_API_KEY=...
ROCKETRIDE_PIPELINE=pr_analyzer

# ---- Database (JawsDB Maria on Heroku) ----
# Local development: set DATABASE_URL
DATABASE_URL=mysql://root:@localhost:3306/pr_analyzer
# On Heroku: JawsDB sets JAWSDB_MARIA_URL automatically after provisioning the add-on
# heroku addons:create jawsdb-maria:kitefin
# JAWSDB_MARIA_URL is set by Heroku — do not set it manually here

# ---- Qdrant Cloud (vectors only) ----
# Get from: https://cloud.qdrant.io
QDRANT_URL=https://your-cluster-id.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=pr_analyzer

# ---- AI Providers ----
# OpenAI for embeddings (text-embedding-3-small). Pipelines use ${ROCKETRIDE_OPENAI_KEY}.
OPENAI_API_KEY=sk-...
# Optional alias (same value as OPENAI_API_KEY):
# ROCKETRIDE_OPENAI_KEY=sk-...

# Anthropic for LLM analysis (claude-opus-4-5) - backend acepta ANTHROPIC_API_KEY o ANTHROPIC_APIKEY
ANTHROPIC_APIKEY=sk-ant-...
# Same secret as ANTHROPIC_API_KEY — pipelines substitute only ${ROCKETRIDE_*} from workspace .env
ROCKETRIDE_ANTHROPIC_APIKEY=sk-ant-...

# ---- Next.js (Frontend) ----
# For local development:
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# URL of the FastAPI backend (used by frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Frontend URL (used by backend for OAuth redirect)
FRONTEND_URL=http://localhost:3000

# ---- Deployment (Heroku) ----
# Set these in Heroku Dashboard or with: heroku config:set KEY=VALUE
# NEXTAUTH_URL=https://your-app.herokuapp.com
# NEXT_PUBLIC_API_URL=https://your-app.herokuapp.com

# ---- Debug ----
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
